      <Item ItemId=";SSH_PSDescription" ItemType="0" PsrId="211" Leaf="true">
        <Str Cat="Text">
          <Val><![CDATA[SSH (Secure Shell) Transport allows connecting Visual Studio to computers running an SSH server with a bash-like shell (ex: Linux, macOS, etc).]]></Val>
          <Tgt Cat="Text" Stat="Loc" Orig="New">
            <Val><![CDATA[O Transporte do SSH (Secure Shell) permite que o Visual Studio se conecte a computadores que estejam executando um servidor SSH com uma shell de tipo busca (ex: Linux, macOS, etc.).]]></Val>
          </Tgt>
        </Str>
        <Disp Icon="Str" />
      </Item>
