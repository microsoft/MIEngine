      <Item ItemId=";Podman_PSDescription" ItemType="0" PsrId="211" Leaf="true">
        <Str Cat="Text">
          <Val><![CDATA[The Podman (Linux Container) connection type allows Visual Studio to connect to Podman containers running locally or remotely (using SSH).]]></Val>
          <Tgt Cat="Text" Stat="Loc" Orig="New">
            <Val><![CDATA[O tipo de conexão Podman (contêiner do Linux) permite que o Visual Studio se conecte a contêineres Podman em execução local ou remota (usando SSH).]]></Val>
          </Tgt>
        </Str>
        <Disp Icon="Str" />
